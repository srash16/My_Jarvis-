# --- Chrome profile nicknames (nickname=email, semicolon separated) ---
# Say "open Chrome with work account" instead of full email
JARVIS_CHROME_NICKNAMES=work=mmcoe.edu.in;college=srushtisatdive2024.ainds@mmcoe.edu.in;personal=srushti.0216@gmail.com

# --- Custom app paths (name=path or command, semicolon separated) ---
# JARVIS_CUSTOM_APPS=obs=C:\Program Files\obs-studio\bin\64bit\obs64.exe

# --- Shutdown/restart delay in seconds (default 30) ---
JARVIS_POWER_DELAY=30

# --- Gmail accounts for sending email (format: nickname=email:app_password, semicolon separated) ---
# Each Gmail account needs its own 16-char App Password:
# Google Account -> Security -> 2-Step Verification -> App passwords
# (requires 2FA enabled on that specific account)
JARVIS_GMAIL_ACCOUNTS=work=you@work.com:xxxxxxxxxxxxxxxx;personal=you@gmail.com:yyyyyyyyyyyyyyyy
JARVIS_GMAIL_DEFAULT=personal

# --- Vision system (enable/disable webcam-based object/action detection) ---
# Set to false to disable the camera watcher (useful for privacy or laptops without a usable webcam)
# On-demand camera vision (voice: "Jarvis, what's this?") — camera opens only for that request
JARVIS_VISION_ENABLED=true

# --- Audio output (optional) ---
# Leave unset to auto-prefer Realtek speakers/headphones over TVs/HDMI.
# Or set a device index / name substring, e.g.:
# JARVIS_OUTPUT_DEVICE=Realtek
# JARVIS_OUTPUT_DEVICE=4

# --- Memory encryption at rest (REQUIRED) ---
# Generate once (e.g. python -c "import secrets; print(secrets.token_hex(32))")
# Never commit the real key. If missing, JARVIS prints a key and exits until you save it.
# After adding a key for an existing plaintext jarvis_memory.db, run:
#   python migrate_encrypt_existing_data.py
JARVIS_DB_KEY=replace_with_64_char_hex_from_secrets_token_hex_32

# --- Gemini models ---
# Main conversation / tools (jarvis_brain + LangChain agent)
# GEMINI_MODEL=gemini-2.5-flash
# Vision / lightweight calls (separate free-tier quota bucket)
# GEMINI_LITE_MODEL=gemini-2.5-flash-lite

# --- RAG footprint (leaner = fewer tokens per call; override if recall feels thin) ---
# RAG_SEMANTIC_TOP_K=3
# RAG_RECENT_TURNS=3

# --- Screen capture retention (encrypted .png.enc under ~/.jarvis_screenshots/) ---
# JARVIS_SCREENSHOT_RETENTION_HOURS=24
